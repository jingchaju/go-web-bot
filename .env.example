APP_ENV=development
HTTP_ADDR=:8080
LOGGER_LEVEL=debug
LOGGER_TO_FILE=false
LOGGER_FILE=logs/app.log
ANTS_POOL_SIZE=100
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
POSTGRES_DSN=host=localhost user=postgres password=postgres dbname=telegram_bot port=5432 sslmode=disable TimeZone=Asia/Shanghai
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_CONN_MAX_LIFETIME_MINUTES=60
JWT_SECRET=change-me-jwt-secret
ADMIN_SECRET=change-me-admin-hmac-secret
ADMIN_SESSION_TTL_MINUTES=120
ADMIN_ROUTE_PREFIX=/api/admin
FRONTEND_DIST=web/dist
